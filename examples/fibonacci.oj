// Fibonacci demo with functions and lists
kaam fib(n):
    jodi (n <= 1) hoi, tetia:
        return n
    return fib(n - 1) + fib(n - 2)

dhora numbers = []
dhora current = 0

jetialoike (current < 8) bare bare kora:
    numbers.append(fib(current))
    dhora current = current + 1

kua("First 8 Fibonacci numbers:")
kua(numbers)
